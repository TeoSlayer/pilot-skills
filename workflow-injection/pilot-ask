#!/usr/bin/env bash
# pilot-ask: query the pilot directory + matched specialist in one shot.
#
# Usage:
#   pilot-ask "<topic>" "<question>"
#
# Output (stdout):
#   - Specialist's reply data on success
#   - "no_specialist:<topic>" if no relevant specialist found
#   - "no_reply:<host>" if a request timed out
#
# Reads the local catalog cache at ~/.pilot/skills-cache/catalog.json
# (refreshed by pilot-daemon every 15 min). Falls back to live query
# on cache miss.

TOPIC="${1:-}"
QUESTION="${2:-$TOPIC}"
[ -z "$TOPIC" ] && { echo "usage: pilot-ask <topic> [<question>]" >&2; exit 2; }

INBOX="$HOME/.pilot/inbox"
CACHE="$HOME/.pilot/skills-cache/catalog.json"
CACHE_MAX_AGE_SEC=1800

mkdir -p "$INBOX" "$(dirname "$CACHE")"
mtime() { stat -f %m "$1" 2>/dev/null || stat -c %Y "$1" 2>/dev/null; }

# ----- Resolve catalog (cache or live) -----
CATALOG_JSON=""
if [ -f "$CACHE" ]; then
    CACHE_AGE=$(( $(date +%s) - $(mtime "$CACHE") ))
    if [ "$CACHE_AGE" -lt "$CACHE_MAX_AGE_SEC" ]; then
        CATALOG_JSON=$(cat "$CACHE" 2>/dev/null)
    fi
fi

if [ -z "$CATALOG_JSON" ]; then
    echo "(no fresh catalog cache, querying list-agents live...)" >&2
    ANCHOR=$(date +%s)
    pilotctl handshake list-agents 2>/dev/null >/dev/null || true
    pilotctl send-message list-agents --data '/data {"limit":500}' >/dev/null 2>&1 || true
    LATEST=""
    for i in $(seq 1 60); do
        sleep 1
        for f in $(ls -1t "$INBOX"/*.json 2>/dev/null); do
            FT=$(mtime "$f"); [ -z "$FT" ] && continue
            [ "$FT" -lt "$ANCHOR" ] && break
            SRC=$(jq -r '.data | fromjson | .source // empty' "$f" 2>/dev/null) || continue
            if [ "$SRC" = "list-agents" ]; then LATEST="$f"; break 2; fi
        done
    done
    if [ -n "$LATEST" ]; then
        CATALOG_JSON=$(jq -r '.data | fromjson' "$LATEST")
        echo "$CATALOG_JSON" > "$CACHE"
    fi
fi

if [ -z "$CATALOG_JSON" ]; then
    echo "no_specialist:$TOPIC"
    exit 0
fi

# ----- Tokenized matching -----
# Split topic into word-tokens (also split compounds heuristically).
# A specialist is a candidate if ANY topic-token appears in
# hostname OR category OR description.

# Generate topic tokens. Lower-case, split on space/hyphen/underscore,
# also extract substring fragments for compound words (e.g. "hackernews"
# becomes "hackernews", "hacker", "news" — splitting on common bigram
# boundaries via shell heuristics is hard, so we just try the topic
# wholesale + each space-split word + and a few common compound splits).
TOPIC_LC=$(echo "$TOPIC" | tr '[:upper:]' '[:lower:]')
# Build a JSON array of probe tokens
TOKENS_JSON=$(printf '%s' "$TOPIC_LC" | tr ' -_' '\n' | jq -R . | jq -s '. + ["'"$TOPIC_LC"'"]')

SPECIALIST=$(echo "$CATALOG_JSON" | jq -r --argjson tokens "$TOKENS_JSON" '
    # For a token, generate probe variants:
    #   - the full token
    #   - 6-char prefix (if token >= 7 chars)   e.g. "hackernews" -> "hacker"
    #   - 7-char prefix (if token >= 8 chars)   e.g. "currencies" -> "currenc"
    # 4- and 5-char prefixes were too noisy (e.g. "haik" of "haiku").
    def probes($t):
        [$t]
        + (if ($t | length) >= 7 then [$t[:6]] else [] end)
        + (if ($t | length) >= 8 then [$t[:7]] else [] end)
        | unique;

    # Start-of-word match. The probe must begin at a word boundary
    # (start of string, or preceded by a non-alnum character) — but it
    # can extend into the middle of a longer word. This prevents short
    # tokens from latching onto interior substrings ("the" inside
    # "weather", "news" inside "newsapi") while still allowing prefix
    # probes like "curren" to match "currencies". Special regex chars
    # in $p are escaped before testing.
    def wb($hay; $p):
        ($p | length) as $L
        | if $L == 0 then false
          else $hay | test("(^|[^a-z0-9])" + ($p | gsub("([.+*?^$()\\[\\]{}\\\\|])"; "\\\\\\1")))
          end;

    # The full topic phrase (last element of $tokens). Multi-word
    # matches deserve more weight than the per-token sum because they
    # confirm the specialist actually addresses the specific query
    # (e.g. "hacker news" -> hn-top rather than newsapi-headlines).
    ($tokens[-1] // "" | ascii_downcase) as $phrase |
    ($phrase | length) as $phrase_len |

    [(.tiers // {}) | to_entries[] | .value.items[]?] + [.items[]?] |
    # Dedup by hostname while preserving original order
    (reduce .[] as $x ([]; if any(.[]; .hostname == $x.hostname) then . else . + [$x] end)) |
    to_entries | map(.value + {_idx: .key}) |
    map(
        . as $row |
        ($row.hostname // "" | ascii_downcase) as $host |
        ($row.category // "" | ascii_downcase) as $cat |
        ($row.description // "" | ascii_downcase) as $desc |
        $row + {
            score: (
                ([ $tokens[]
                  | select(type == "string" and length >= 3)
                  | ascii_downcase
                  | . as $tok
                  | probes($tok)
                  | map(. as $p |
                        if   wb($host; $p) then 50
                        elif wb($cat;  $p) then 20
                        elif wb($desc; $p) then 10
                        else 0 end)
                  | max
                ] | add // 0)
                +
                # Phrase bonus: for multi-word topics, reward fields that
                # contain the full phrase (not just individual tokens).
                (if ($phrase_len > 0) and ($phrase | contains(" "))
                 then
                     if   wb($host; $phrase) then 100
                     elif wb($cat;  $phrase) then 50
                     elif wb($desc; $phrase) then 30
                     else 0 end
                 else 0 end)
            )
        }
    ) |
    sort_by(-.score, ._idx) |
    .[0] |
    if (.score // 0) > 0 then .hostname else empty end
' 2>/dev/null)

if [ -z "$SPECIALIST" ] || [ "$SPECIALIST" = "null" ]; then
    echo "no_specialist:$TOPIC"
    exit 0
fi

echo "specialist=$SPECIALIST" >&2
ANCHOR2=$(date +%s)
# RPC_TIMEOUT bounds the underlying pilotctl call; PILOT_ASK_TIMEOUT
# bounds the inbox poll. Both default to 30s. Benchmarks override to
# small values so honest fallback fires quickly when the network is
# unreachable instead of blocking the agent's turn for 30s.
RPC_TIMEOUT=${PILOT_ASK_RPC_TIMEOUT:-30}
timeout "$RPC_TIMEOUT" pilotctl handshake "$SPECIALIST" 2>/dev/null >/dev/null || true
timeout "$RPC_TIMEOUT" pilotctl send-message "$SPECIALIST" --data "$QUESTION" >/dev/null 2>&1 || true

REPLY=""
TIMEOUT=${PILOT_ASK_TIMEOUT:-30}
for i in $(seq 1 "$TIMEOUT"); do
    sleep 1
    for f in $(ls -1t "$INBOX"/*.json 2>/dev/null); do
        FT=$(mtime "$f"); [ -z "$FT" ] && continue
        [ "$FT" -lt "$ANCHOR2" ] && break
        AG=$(jq -r '.data | fromjson | .agent // empty' "$f" 2>/dev/null) || continue
        if [ "$AG" = "$SPECIALIST" ]; then REPLY="$f"; break 2; fi
    done
done

if [ -z "$REPLY" ]; then
    echo "no_reply:$SPECIALIST"
    exit 0
fi
jq -r '.data' "$REPLY"
