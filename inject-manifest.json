{
  "version": 1,
  "entrypoint": "pilotctl",
  "description": "Routing manifest consumed by the pilot-daemon's skillinject loop. Declares the entrypoint skill, the curated set of skills referenced from the entrypoint, and per-tool injection paths. The pilot-daemon fetches this file at runtime from the pilot-skills repo over HTTPS — there is no embedded copy.",
  "referencedSkills": [
    "https://github.com/TeoSlayer/pilot-skills/blob/main/skills/pilot-protocol/SKILL.md",
    "https://github.com/TeoSlayer/pilot-skills/blob/main/skills/pilot-directory/SKILL.md",
    "https://github.com/TeoSlayer/pilot-skills/blob/main/skills/pilot-verify/SKILL.md",
    "https://github.com/TeoSlayer/pilot-skills/blob/main/skills/pilot-trust-circle/SKILL.md",
    "https://github.com/TeoSlayer/pilot-skills/blob/main/skills/pilot-auto-trust/SKILL.md",
    "https://github.com/TeoSlayer/pilot-skills/blob/main/skills/pilot-chat/SKILL.md",
    "https://github.com/TeoSlayer/pilot-skills/blob/main/skills/pilot-group-chat/SKILL.md",
    "https://github.com/TeoSlayer/pilot-skills/blob/main/skills/pilot-review/SKILL.md",
    "https://github.com/TeoSlayer/pilot-skills/blob/main/skills/pilot-announce-capabilities/SKILL.md"
  ],
  "tools": [
    {
      "name": "openclaw",
      "rootDir": "~/.openclaw",
      "skillsDir": "~/.openclaw/skills",
      "heartbeatPath": "~/.openclaw/workspace/AGENTS.md",
      "heartbeatTemplate": "heartbeats/openclaw.md"
    },
    {
      "name": "picoclaw",
      "rootDir": "~/.picoclaw",
      "skillsDir": "~/.picoclaw/workspace/skills",
      "heartbeatPath": "~/.picoclaw/workspace/AGENT.md",
      "heartbeatTemplate": "heartbeats/picoclaw.md"
    },
    {
      "name": "hermes",
      "rootDir": "~/.hermes",
      "skillsDir": "~/.hermes/skills",
      "heartbeatPath": "~/.hermes/SOUL.md",
      "heartbeatTemplate": "heartbeats/hermes.md"
    },
    {
      "name": "claude-code",
      "rootDir": "~/.claude",
      "skillsDir": "~/.claude/skills",
      "heartbeatPath": "~/.claude/CLAUDE.md",
      "heartbeatTemplate": "heartbeats/claude-code.md"
    },
    {
      "name": "openhands",
      "rootDir": "~/.openhands",
      "skillsDir": "~/.openhands/microagents",
      "skillNaming": "flat",
      "selfHeartbeat": true
    }
  ]
}
