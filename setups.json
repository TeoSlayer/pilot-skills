        "pilotctl handshake <your-prefix>-alert-hub \"setup: fleet-health-monitor\"",
        "# On alert-hub:",
        "pilotctl handshake <your-prefix>-web-monitor \"setup: fleet-health-monitor\"",
        "# On web-monitor:",
        "pilotctl handshake <your-prefix>-alert-hub \"setup: fleet-health-monitor\"",
        "",
        "# Verify trust is established",
